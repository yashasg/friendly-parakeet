{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "shapeshifter",
  "version": "0.1.0",
  "description": "Endless runner with shape-shifting and burnout scoring",
  "dependencies": [
    "entt",
    "magic-enum",
    { "name": "sdl2", "platform": "!emscripten" },
    { "name": "sdl2-mixer", "platform": "!emscripten", "features": ["libflac"] },
    { "name": "sdl2-ttf", "platform": "!emscripten" },
    "nlohmann-json",
    { "name": "catch2", "platform": "!linux" }
  ]
}
