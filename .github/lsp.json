{
  "lspServers": {
    "clangd": {
      "command": "clangd-20",
      "args": ["--compile-commands-dir=build", "--background-index", "--clang-tidy", "--header-insertion=never"],
      "fileExtensions": {
        ".cpp": "cpp",
        ".hpp": "cpp",
        ".h": "cpp",
        ".c": "c"
      }
    }
  }
}
