# rgl layout text file (v4.0) - raygui layout file generated using rGuiLayout
# Tutorial Screen Layout - 720x1280 portrait
# Reference: tutorial.json design specification
# Target exports: app/ui/tutorial.h, app/ui/tutorial.c
#
# Note: Shape demo elements (circle/square/triangle at y_n 0.34) and
# platform-specific text require adapter logic to render actual shapes
# and select appropriate platform text. DummyRec controls are used as
# layout guides for shape placement.
#
# Ref. window:    r <x> <y> <width> <height>
# Anchor info:    a <id> <name> <posx> <posy> <enabled>
# Control info:   c <id> <type> <name> <rectangle> <anchor_id> <text>
#
r 0 0 720 1280
a 001 Anchor01 0 0 1
c 000 4 TutorialTitle 160 205 400 48 1 QUICK START
